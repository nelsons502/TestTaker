# Supabase — required for TestTaker
# Get these from your Supabase project dashboard: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Cookie domain — when TestTaker is deployed alongside the main site, set this
# to the parent domain (e.g. ".focus-coding.com") so the auth session set on
# focus-coding.com is recognized on tests.focus-coding.com. Leave EMPTY when
# running standalone or for localhost dev.
NEXT_PUBLIC_COOKIE_DOMAIN=
